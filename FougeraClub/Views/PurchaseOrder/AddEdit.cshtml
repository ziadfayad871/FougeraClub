@model FougeraClub.Application.DTOs.PurchaseOrderDto

@{
    ViewData["Title"] = Model.Id == 0 ? "إضافة أمر شراء" : "تعديل أمر شراء";
    var suppliers = ViewBag.Suppliers as IEnumerable<FougeraClub.Application.DTOs.SupplierLookupDto>;
    var pageHeading = Model.Id == 0 ? "إضافة أمر شراء" : "تعديل أمر شراء";
    var items = Model.Items ?? new List<FougeraClub.Application.DTOs.PurchaseOrderItemDto>();
    var itemCount = items.Count;
}

<div class="content-page purchase-order-editor-page" dir="ltr">
    <div class="content">
        <div class="container-fluid">
            <div class="purchase-page-header">
                <nav class="purchase-breadcrumb-nav" aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item active" aria-current="page">
                            @pageHeading
                        </li>
                        <li class="purchase-breadcrumb-divider" aria-hidden="true">
                            <i class="fa-solid fa-chevron-left"></i>
                        </li>
                        <li class="breadcrumb-item">
                            <a href="/Admin/PurchaseOrder/Index">قائمة أوامر الشراء</a>
                        </li>
                        <li class="purchase-breadcrumb-divider" aria-hidden="true">
                            <i class="fa-solid fa-chevron-left"></i>
                        </li>
                        <li class="breadcrumb-item">
                            <a href="/Admin/Home/Index">وحدة أوامر الشراء</a>
                        </li>
                    </ol>
                </nav>

                <div class="purchase-page-title-wrap">
                    <h4 class="ico-header-title my-0">
                        <span class="fa-solid fa-cart-shopping text-ico"></span>
                        @pageHeading
                    </h4>
                </div>
            </div>

            <div class="card all-borders purchase-order-card">
                <div class="card-body purchase-order-card-body">
                    <form asp-action="AddEdit" method="post" id="purchaseOrderForm">
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-4">
                            <div class="col-lg-6">
                                <label class="form-label purchase-label-highlight">رقم أمر الشراء</label>
                                <input asp-for="OrderNumber" class="form-control purchase-form-control purchase-order-number purchase-readonly" readonly />
                            </div>

                            <div class="col-lg-6">
                                <label class="form-label required-label">المورد</label>
                                <select asp-for="SupplierId" class="form-select select2 purchase-form-control" data-placeholder="-- اختر المورد --" required>
                                    <option value="">-- اختر المورد --</option>
                                    @if (suppliers != null)
                                    {
                                        foreach (var supplier in suppliers)
                                        {
                                            <option value="@supplier.Id">@supplier.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-lg-6">
                                <label class="form-label purchase-label-muted">الضريبة</label>
                                <div class="purchase-vat-box purchase-vat-box-inline">
                                    <div class="form-check form-switch m-0 purchase-vat-switch">
                                        <input asp-for="ApplyVat" class="form-check-input" type="checkbox" id="vatCheckbox">
                                        <label class="form-check-label fw-bold" for="vatCheckbox">With 5% VAT</label>
                                    </div>
                                </div>
                            </div>

                            <div class="col-lg-6">
                                <label class="form-label required-label">التاريخ</label>
                                <div class="purchase-date-wrap">
                                    <input asp-for="OrderDate" type="date" class="form-control purchase-form-control purchase-date-input" required value="@Model.OrderDate.ToString("yyyy-MM-dd")" />
                                    <span class="purchase-date-icon">
                                        <i class="fa-regular fa-calendar-days"></i>
                                    </span>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="purchase-section-title">إضافة بنود أمر الشراء</div>
                            </div>

                            <div class="col-lg-6">
                                <label class="form-label required-label">سعر الوحدة</label>
                                <input type="number" id="entryPrice" class="form-control purchase-form-control" step="0.01" placeholder="أدخل سعر الوحدة" />
                            </div>

                            <div class="col-lg-6">
                                <label class="form-label required-label">الكمية</label>
                                <input type="number" id="entryQty" class="form-control purchase-form-control" step="0.01" placeholder="أدخل الكمية" />
                            </div>

                            <div class="col-12">
                                <label class="form-label required-label">البيان</label>
                                <textarea id="entryStatement" class="form-control purchase-form-control purchase-statement" rows="2" placeholder="أدخل البيان"></textarea>
                            </div>

                            <div class="col-12">
                                <div class="purchase-item-action-row">
                                    <button type="button" class="btn btn-success purchase-add-item-btn" onclick="addItemToList()">
                                        إضافة
                                        <i class="fa-solid fa-cart-plus ms-2"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="purchase-section-title">بنود أمر الشراء</div>
                            </div>

                            <div class="col-12">
                                <div class="table-responsive purchase-items-table-wrap">
                                    <table class="table table-bordered align-middle text-center mb-0 purchase-items-table" id="itemsTable">
                                        <thead>
                                            <tr>
                                                <th style="width: 20%;">الكمية</th>
                                                <th style="width: 28%;">سعر الوحدة</th>
                                                <th style="width: 32%;">البيان</th>
                                                <th style="width: 20%;">أدوات التحكم</th>
                                            </tr>
                                        </thead>
                                        <tbody id="itemsBody">
                                            @if (itemCount > 0)
                                            {
                                                for (int i = 0; i < itemCount; i++)
                                                {
                                                    <tr class="item-row">
                                                        <td class="fw-bold text-dark">
                                                            <input type="hidden" name="Items[@i].Quantity" value="@items[i].Quantity" />
                                                            @items[i].Quantity
                                                        </td>
                                                        <td class="text-dark">
                                                            <input type="hidden" name="Items[@i].UnitPrice" value="@items[i].UnitPrice" />
                                                            @items[i].UnitPrice.ToString("N2")
                                                        </td>
                                                        <td class="text-dark fw-medium purchase-item-name-cell">
                                                            <input type="hidden" name="Items[@i].ItemName" value="@items[i].ItemName" />
                                                            @items[i].ItemName
                                                        </td>
                                                        <td>
                                                            <button type="button" class="btn-control btn-icon btn-sm rounded-circle purchase-row-action-btn" onclick="removeRow(this)">
                                                                <i class="fa-solid fa-trash"></i>
                                                            </button>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr id="itemsEmptyState">
                                                    <td colspan="4" class="purchase-empty-state">لا توجد بنود مضافة حالياً</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="purchase-total-row">
                                    <div class="purchase-total-field-wrap">
                                        <label class="form-label fw-bold">الإجمالي النهائي</label>
                                        <input type="text" id="grandTotalDisplay" class="form-control purchase-form-control purchase-readonly purchase-total-display" readonly value="0.00" />
                                    </div>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="purchase-form-actions">
                                    <button type="submit" class="btn btn-success purchase-submit-btn">
                                        حفظ
                                        <i class="fa-solid fa-floppy-disk ms-2"></i>
                                    </button>
                                    <a class="btn purchase-back-btn" href="/Admin/PurchaseOrder/Index">
                                        رجوع
                                        <i class="fa-solid fa-arrow-left ms-2"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .purchase-order-editor-page .container-fluid {
        max-width: calc(100% - 24px);
    }

    .purchase-page-header {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
        margin: 12px 0 16px;
    }

    .purchase-breadcrumb-nav {
        width: 100%;
        direction: rtl;
    }

    .purchase-breadcrumb-nav .breadcrumb {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 8px;
        margin: 0;
        padding: 0;
    }

    .purchase-breadcrumb-nav .breadcrumb-item {
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
    }

    .purchase-breadcrumb-nav .breadcrumb-item + .breadcrumb-item::before {
        display: none;
    }

    .purchase-breadcrumb-nav .breadcrumb-item a,
    .purchase-breadcrumb-nav .breadcrumb-item.active {
        color: #64748b;
        text-decoration: none;
    }

    .purchase-breadcrumb-nav .breadcrumb-item.active {
        color: #94a3b8;
    }

    .purchase-breadcrumb-divider {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 11px;
    }

    .purchase-page-title-wrap {
        width: 100%;
        display: flex;
        justify-content: flex-end;
    }

    .purchase-page-title-wrap .ico-header-title {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 1.65rem;
        text-align: right;
        direction: rtl;
        border-right: 0;
        padding-right: 0;
    }

    .purchase-page-title-wrap .ico-header-title::before {
        display: none;
    }

    .purchase-page-title-wrap .ico-header-title::after {
        display: none;
    }

    .purchase-order-card {
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.05);
    }

    .purchase-order-card-body {
        padding: 1.85rem 1.95rem;
    }

    .purchase-order-card .form-label {
        color: #4aa84d;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: block;
        width: 100%;
        text-align: right;
    }

    .purchase-label-highlight {
        color: #6ab54f !important;
    }

    .purchase-label-muted {
        color: #7bb05c !important;
    }

    .required-label::after {
        content: " *";
        color: #dc3545;
    }

    .purchase-form-control,
    .purchase-order-editor-page .select2-container--default .select2-selection--single {
        min-height: 40px;
        border: 1px solid #d7dde5 !important;
        border-radius: 0.45rem !important;
        font-size: 15px;
        text-align: right;
        direction: rtl;
        background-color: #fff;
    }

    .purchase-order-editor-page .purchase-form-control::placeholder,
    .purchase-order-editor-page textarea::placeholder,
    .purchase-order-editor-page input::placeholder {
        text-align: right;
        direction: rtl;
    }

    .purchase-order-editor-page .form-control:focus,
    .purchase-order-editor-page .form-select:focus {
        border-color: #85c870;
        box-shadow: none;
    }

    .purchase-order-editor-page .select2-container {
        width: 100% !important;
    }

    .purchase-order-editor-page .select2-container--default .select2-selection--single {
        display: flex;
        align-items: center;
    }

    .purchase-order-editor-page .select2-container--default .select2-selection--single .select2-selection__rendered {
        line-height: 38px;
        padding-right: 32px;
        padding-left: 14px;
        color: #5b6572;
        text-align: right;
        direction: rtl;
    }

    .purchase-order-editor-page .select2-container--default .select2-selection--single .select2-selection__placeholder {
        text-align: right;
        direction: rtl;
    }

    .purchase-order-editor-page .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 38px;
    }

    .purchase-order-number {
        font-weight: 700;
        color: #5b6572;
        background-color: #fafbfd !important;
    }

    .purchase-readonly {
        background-color: #fafbfd !important;
        border-color: #e1e6ec !important;
    }

    .purchase-date-wrap {
        position: relative;
    }

    .purchase-date-input {
        padding-right: 42px;
        padding-left: 0.75rem;
        text-align: right;
    }

    .purchase-date-icon {
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #727c87;
        pointer-events: none;
    }

    .purchase-vat-box {
        min-height: 40px;
        border: 1px solid #d7dde5;
        border-radius: 0.45rem;
        background: #fff;
        padding: 0.5rem 0.85rem;
        display: flex;
        align-items: center;
    }

    .purchase-vat-box-inline {
        justify-content: flex-end;
    }

    .purchase-vat-switch {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .purchase-vat-box .form-check-input {
        width: 42px;
        height: 22px;
        float: none;
        margin: 0;
        cursor: pointer;
    }

    .purchase-vat-switch .form-check-label {
        color: #77b85a;
        font-size: 15px;
        text-align: right;
    }

    .purchase-section-title {
        display: inline-flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: flex-start;
        gap: 8px;
        color: #6ab54f;
        font-size: 1.3rem;
        font-weight: 700;
        width: 100%;
        margin-top: 0.25rem;
        text-align: right;
    }

    .purchase-section-title::after {
        content: "";
        width: 34px;
        height: 4px;
        border-radius: 999px;
        background: #9dd67f;
    }

    .purchase-statement {
        min-height: 46px;
        resize: vertical;
    }

    .purchase-item-action-row {
        display: flex;
        justify-content: flex-start;
        width: 100%;
    }

    .purchase-add-item-btn {
        min-width: 144px;
        height: 42px;
        border-radius: 0.5rem;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .purchase-items-table-wrap {
        border-radius: 0.75rem;
        overflow: hidden;
        border: 1px solid #d8e0e8;
        background: #fff;
    }

    .purchase-items-table {
        margin-bottom: 0;
        direction: rtl;
    }

    .purchase-items-table thead th {
        background: #46ab43;
        color: #fff;
        font-weight: 700;
        white-space: nowrap;
        padding: 0.9rem 0.75rem;
        border-color: rgba(255, 255, 255, 0.25);
    }

    .purchase-items-table td {
        vertical-align: middle;
        font-size: 14px;
        padding: 0.9rem 0.75rem;
    }

    .purchase-item-name-cell {
        text-align: center;
    }

    .purchase-empty-state {
        color: #94a3b8;
        font-weight: 600;
        padding: 1.25rem 0.75rem !important;
    }

    .purchase-total-row {
        display: flex;
        justify-content: flex-end;
    }

    .purchase-total-field-wrap {
        width: 100%;
        max-width: 340px;
        text-align: right;
    }

    .purchase-total-field-wrap .form-label {
        text-align: right;
        width: 100%;
    }

    .purchase-total-display {
        font-weight: 800;
        color: #009ec7;
    }

    .purchase-row-action-btn {
        width: 30px;
        height: 30px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: #dc3545;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    .purchase-row-action-btn:hover {
        background-color: #dc3545;
        border-color: #dc3545;
        color: #fff;
    }

    .purchase-form-actions {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        flex-wrap: wrap;
        gap: 12px;
        width: 100%;
    }

    .purchase-submit-btn,
    .purchase-back-btn {
        min-width: 86px;
        height: 42px;
        border-radius: 0.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
    }

    .purchase-back-btn {
        background: #9fd971;
        border: 1px solid #9fd971;
        color: #fff;
    }

    .purchase-back-btn:hover {
        background: #8bc85f;
        border-color: #8bc85f;
        color: #fff;
    }

    @@media (max-width: 992px) {
        .purchase-order-card-body {
            padding: 1.25rem;
        }

        .purchase-page-title-wrap {
            justify-content: flex-end;
        }

        .purchase-breadcrumb-nav .breadcrumb {
            justify-content: flex-start;
        }
    }

    @@media (max-width: 768px) {
        .purchase-page-header {
            align-items: stretch;
        }

        .purchase-order-card-body {
            padding: 1rem;
        }

        .purchase-form-actions {
            flex-direction: row;
            align-items: center;
            justify-content: flex-start;
        }

        .purchase-submit-btn,
        .purchase-back-btn,
        .purchase-add-item-btn {
            width: auto;
        }

        .purchase-total-row {
            justify-content: stretch;
        }

        .purchase-total-field-wrap {
            max-width: 100%;
            text-align: right;
        }

        .purchase-total-field-wrap .form-label {
            text-align: right;
        }

        .purchase-vat-box-inline {
            justify-content: center;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            if ($.fn.select2) {
                $('.select2').select2({
                    dir: 'rtl',
                    dropdownParent: $('#purchaseOrderForm'),
                    placeholder: function () {
                        return $(this).data('placeholder') || '';
                    },
                    allowClear: true
                });
            }

            updateGrandTotal();
            toggleItemsEmptyState();

            $('#vatCheckbox').change(function () {
                updateGrandTotal();
            });
        });

        function addItemToList() {
            var qty = parseFloat($('#entryQty').val()) || 0;
            var price = parseFloat($('#entryPrice').val()) || 0;
            var statement = $('#entryStatement').val().trim();

            if (statement === "") {
                toastr.error("يجب إدخال البيان");
                return;
            }

            if (qty <= 0) {
                toastr.error("الكمية يجب أن تكون أكبر من صفر");
                return;
            }

            if (price <= 0) {
                toastr.error("سعر الوحدة يجب أن يكون أكبر من صفر");
                return;
            }

            var index = $('#itemsBody tr.item-row').length;
            var newRow = `
                <tr class="item-row">
                    <td class="fw-bold text-dark">
                        <input type="hidden" name="Items[${index}].Quantity" value="${qty}" />
                        ${qty}
                    </td>
                    <td class="text-dark">
                        <input type="hidden" name="Items[${index}].UnitPrice" value="${price}" />
                        ${price.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                    </td>
                    <td class="text-dark fw-medium purchase-item-name-cell">
                        <input type="hidden" name="Items[${index}].ItemName" value="${statement}" />
                        ${statement}
                    </td>
                    <td>
                        <button type="button" class="btn-control btn-icon btn-sm rounded-circle purchase-row-action-btn" onclick="removeRow(this)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>`;

            $('#itemsBody').append(newRow);
            $('#entryQty').val('');
            $('#entryPrice').val('');
            $('#entryStatement').val('');

            reIndexRows();
            toggleItemsEmptyState();
            updateGrandTotal();
            toastr.info("تمت إضافة البند إلى القائمة");
        }

        function confirmRemoveRow() {
            if (window.Swal && Swal.fire) {
                return Swal.fire({
                    title: 'هل أنت متأكد من حذف هذا البند؟',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'نعم، احذف',
                    cancelButtonText: 'إلغاء',
                    confirmButtonColor: '#47a744',
                    reverseButtons: true,
                    focusCancel: true
                }).then(function (result) {
                    return !!result.isConfirmed;
                });
            }

            return Promise.resolve(window.confirm('هل أنت متأكد من حذف هذا البند؟'));
        }

        function removeRow(btn) {
            confirmRemoveRow().then(function (ok) {
                if (!ok) {
                    return;
                }

                $(btn).closest('tr').remove();
                reIndexRows();
                toggleItemsEmptyState();
                updateGrandTotal();
            });
        }

        function reIndexRows() {
            $('#itemsBody tr.item-row').each(function (index, row) {
                $(row).find('input').each(function () {
                    var name = $(this).attr('name');
                    if (name) {
                        $(this).attr('name', name.replace(/\[\d+\]/, '[' + index + ']'));
                    }
                });
            });
        }

        function toggleItemsEmptyState() {
            var itemRows = $('#itemsBody tr.item-row');
            var emptyState = $('#itemsEmptyState');

            if (itemRows.length === 0) {
                if (emptyState.length === 0) {
                    $('#itemsBody').append('<tr id="itemsEmptyState"><td colspan="4" class="purchase-empty-state">لا توجد بنود مضافة حالياً</td></tr>');
                }
            } else {
                emptyState.remove();
            }
        }

        function updateGrandTotal() {
            var total = 0;

            $('#itemsBody tr.item-row').each(function () {
                var qty = parseFloat($(this).find('input[name*="Quantity"]').val()) || 0;
                var price = parseFloat($(this).find('input[name*="UnitPrice"]').val()) || 0;
                total += qty * price;
            });

            var applyVat = $('#vatCheckbox').is(':checked');
            var vat = applyVat ? (total * 0.05) : 0;
            var grandTotal = total + vat;

            $('#grandTotalDisplay').val(grandTotal.toLocaleString(undefined, {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }));
        }
    </script>
}
