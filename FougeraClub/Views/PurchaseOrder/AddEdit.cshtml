@model FougeraClub.Application.DTOs.PurchaseOrderDto

@{
    ViewData["Title"] = Model.Id == 0 ? "إنشاء أمر شراء" : "تعديل أمر شراء";
    var suppliers = ViewBag.Suppliers as IEnumerable<FougeraClub.Application.DTOs.SupplierLookupDto>;
    var pageHeading = Model.Id == 0 ? "إنشاء أمر شراء" : "تعديل أمر شراء";
}

<div class="content-page purchase-order-editor-page" dir="rtl">
    <div class="content">
        <div class="container-fluid">
            <div class="row my-3 d-flex justify-content-between align-items-center flex-wrap">
                <div class="col-md-6 mb-2">
                    <div class="d-flex align-items-center">
                        <h4 class="ico-header-title my-1 ms-lg-1 ms-md-1">
                            <span class="fa fa-book me-2 text-ico"></span>
                            @pageHeading
                        </h4>
                    </div>
                </div>
                <div class="col-md-6 mb-2">
                    <nav class="d-flex align-items-center justify-content-end" aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0 py-2 flex-nowrap">
                            <li class="breadcrumb-item">
                                <a href="/Admin/Home/Index">أوامر الشراء</a>
                            </li>
                            <li class="breadcrumb-item">
                                <a href="/Admin/PurchaseOrder/Index">قائمة أوامر الشراء</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">
                                @pageHeading
                            </li>
                        </ol>
                    </nav>
                </div>
            </div>

            <div class="card all-borders p-3 purchase-order-card">
                <form asp-action="AddEdit" method="post" id="purchaseOrderForm">
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">المورد</label>
                            <select asp-for="SupplierId" class="form-select select2 purchase-form-control" data-placeholder="اختر المورد" required>
                                <option value="">اختر المورد</option>
                                @if (suppliers != null)
                                {
                                    foreach (var supplier in suppliers)
                                    {
                                        <option value="@supplier.Id">@supplier.Name</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-3 mb-2">
                            <label class="form-label">التاريخ</label>
                            <input asp-for="OrderDate" type="date" class="form-control purchase-form-control" placeholder="اختر التاريخ" required value="@Model.OrderDate.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-3 mb-2">
                            <label class="form-label">رقم أمر الشراء</label>
                            <input asp-for="OrderNumber" class="form-control fw-bold bg-light purchase-form-control purchase-readonly text-primary" placeholder="رقم أمر الشراء" readonly />
                        </div>

                        <div class="col-md-6 mb-2">
                            <label class="form-label">الضريبة</label>
                            <div class="purchase-vat-box">
                                <div class="form-check form-switch m-0 purchase-vat-switch">
                                    <input asp-for="ApplyVat" class="form-check-input" type="checkbox" id="vatCheckbox">
                                    <label class="form-check-label fw-bold" for="vatCheckbox">تطبيق VAT 5%</label>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-2">
                            <label class="form-label fw-bold">الإجمالي النهائي</label>
                            <input type="text" id="grandTotalDisplay" class="form-control fw-bold bg-light purchase-form-control purchase-readonly text-primary" placeholder="الإجمالي النهائي" readonly value="0.00" />
                        </div>

                        <div class="col-12">
                            <div class="purchase-divider"></div>
                        </div>

                        <div class="col-md-3 mb-2">
                            <label class="form-label">الكمية</label>
                            <input type="number" id="entryQty" class="form-control purchase-form-control" step="0.01" placeholder="أدخل الكمية" />
                        </div>

                        <div class="col-md-3 mb-2">
                            <label class="form-label">سعر الوحدة</label>
                            <input type="number" id="entryPrice" class="form-control purchase-form-control" step="0.01" placeholder="أدخل سعر الوحدة" />
                        </div>

                        <div class="col-md-6 mb-2">
                            <label class="form-label">البيان</label>
                            <textarea id="entryStatement" class="form-control purchase-form-control purchase-statement" rows="2" placeholder="أدخل البيان أو الوصف"></textarea>
                        </div>

                        <div class="col-12">
                            <div class="d-flex justify-content-end mt-2">
                                <button type="button" class="btn btn-success btn-sm px-3 purchase-save-item-btn" onclick="addItemToList()">
                                    <i class="fa-solid fa-plus me-1"></i> حفظ البند
                                </button>
                            </div>
                        </div>

                        <div class="col-12 mt-3">
                            <div class="table-responsive purchase-items-table-wrap">
                                <table class="table table-bordered table-hover table-striped mb-0 text-center purchase-items-table" id="itemsTable">
                                    <thead>
                                        <tr>
                                            <th style="width: 15%;">الكمية</th>
                                            <th style="width: 15%;">سعر الوحدة</th>
                                            <th style="width: 55%;" class="text-start">البيان</th>
                                            <th style="width: 15%;">أدوات التحكم</th>
                                        </tr>
                                    </thead>
                                    <tbody id="itemsBody">
                                        @if (Model.Items != null && Model.Items.Count > 0)
                                        {
                                            for (int i = 0; i < Model.Items.Count; i++)
                                            {
                                                <tr>
                                                    <td class="fw-bold text-dark">
                                                        <input type="hidden" name="Items[@i].Quantity" value="@Model.Items[i].Quantity" />
                                                        @Model.Items[i].Quantity
                                                    </td>
                                                    <td class="text-muted">
                                                        <input type="hidden" name="Items[@i].UnitPrice" value="@Model.Items[i].UnitPrice" />
                                                        @Model.Items[i].UnitPrice.ToString("N2")
                                                    </td>
                                                    <td class="text-start text-dark fw-medium">
                                                        <input type="hidden" name="Items[@i].ItemName" value="@Model.Items[i].ItemName" />
                                                        @Model.Items[i].ItemName
                                                    </td>
                                                    <td>
                                                        <button type="button" class="btn-control btn-icon btn-sm rounded-circle purchase-row-action-btn" onclick="removeRow(this)">
                                                            <i class="fa-solid fa-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="d-flex align-items-center justify-content-end gap-3 mt-3 purchase-form-actions">
                                <button type="submit" class="btn btn-sm px-3 btn-cancel-search">
                                    <i class="fa-solid fa-floppy-disk me-1"></i> حفظ أمر الشراء
                                </button>
                                <a class="btn btn-success btn-sm px-3" href="/Admin/PurchaseOrder/Index">
                                    رجوع <i class="fa-solid fa-arrow-left"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .purchase-order-editor-page .container-fluid {
        max-width: calc(100% - 24px);
    }

    .purchase-order-card {
        border-radius: 10px;
    }

    .purchase-order-card .form-label {
        color: #334155;
        font-weight: 600;
        margin-bottom: 0.35rem;
    }

    .purchase-form-control,
    .purchase-order-editor-page .select2-container--default .select2-selection--single {
        min-height: 38px;
        border: 1px solid #d5dbe3 !important;
        border-radius: 0.375rem !important;
        font-size: 14px;
        text-align: right;
    }

    .purchase-order-editor-page .form-control:focus,
    .purchase-order-editor-page .form-select:focus {
        border-color: #86c67c;
        box-shadow: none;
    }

    .purchase-order-editor-page .select2-container {
        width: 100% !important;
    }

    .purchase-order-editor-page .select2-container--default .select2-selection--single {
        display: flex;
        align-items: center;
        background-color: #fff;
    }

    .purchase-order-editor-page .select2-container--default .select2-selection--single .select2-selection__rendered {
        width: 100%;
        line-height: 36px;
        padding-right: 12px;
        padding-left: 28px;
        text-align: right;
        color: #334155;
        font-size: 14px;
    }

    .purchase-order-editor-page .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 36px;
    }

    .purchase-readonly {
        background-color: #f8f9fa !important;
        border-color: #e2e8f0 !important;
    }

    .purchase-vat-box {
        min-height: 38px;
        border: 1px solid #d5dbe3;
        border-radius: 0.375rem;
        background: #fff;
        padding: 0.5rem 0.75rem;
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .purchase-vat-box .form-check-input {
        width: 40px;
        height: 20px;
        float: none;
        margin-left: 0.5rem;
        margin-right: 0;
        cursor: pointer;
    }

    .purchase-vat-switch {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
    }

    .purchase-vat-switch .form-check-label {
        color: #334155;
    }

    .purchase-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 0.75rem 0 0.5rem;
    }

    .purchase-statement {
        min-height: 38px;
        resize: vertical;
    }

    .purchase-save-item-btn {
        min-width: 120px;
    }

    .purchase-items-table-wrap {
        border: 1px solid #d9e1e8;
        border-radius: 0.5rem;
        overflow: hidden;
        background: #fff;
    }

    .purchase-items-table {
        margin-bottom: 0;
    }

    .purchase-items-table thead th {
        background: #eef3f8;
        color: #475569;
        font-weight: 700;
        white-space: nowrap;
    }

    .purchase-items-table td {
        vertical-align: middle;
        font-size: 14px;
    }

    .purchase-row-action-btn {
        width: 30px;
        height: 30px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        color: #dc3545;
    }

    .purchase-row-action-btn:hover {
        background-color: #dc3545;
        border-color: #dc3545;
        color: #fff;
    }

    .purchase-form-actions .btn {
        min-width: 126px;
    }

    @@media (max-width: 768px) {
        .purchase-form-actions {
            flex-direction: column;
            align-items: stretch !important;
        }

        .purchase-form-actions .btn {
            width: 100%;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            if ($.fn.select2) {
                $('.select2').select2({
                    dir: 'rtl',
                    dropdownParent: $('#purchaseOrderForm'),
                    placeholder: function () {
                        return $(this).data('placeholder') || '';
                    },
                    allowClear: true
                });
            }

            updateGrandTotal();
            $('#vatCheckbox').change(function () { updateGrandTotal(); });
        });

        function addItemToList() {
            var qty = parseFloat($('#entryQty').val()) || 0;
            var price = parseFloat($('#entryPrice').val()) || 0;
            var statement = $('#entryStatement').val().trim();

            if (statement === "") {
                toastr.error("يجب إدخال البيان (الوصف)");
                return;
            }

            if (qty <= 0) {
                toastr.error("الكمية يجب أن تكون أكبر من صفر");
                return;
            }

            var index = $('#itemsBody tr').length;
            var newRow = `
                <tr>
                    <td class="fw-bold text-dark">
                        <input type="hidden" name="Items[${index}].Quantity" value="${qty}" />
                        ${qty}
                    </td>
                    <td class="text-muted">
                        <input type="hidden" name="Items[${index}].UnitPrice" value="${price}" />
                        ${price.toLocaleString(undefined, { minimumFractionDigits: 2 })}
                    </td>
                    <td class="text-start text-dark fw-medium">
                        <input type="hidden" name="Items[${index}].ItemName" value="${statement}" />
                        ${statement}
                    </td>
                    <td>
                        <button type="button" class="btn-control btn-icon btn-sm rounded-circle purchase-row-action-btn" onclick="removeRow(this)">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </td>
                </tr>`;

            $('#itemsBody').append(newRow);
            $('#entryQty').val('');
            $('#entryPrice').val('');
            $('#entryStatement').val("");

            reIndexRows();
            updateGrandTotal();
            toastr.info("تمت إضافة البند إلى القائمة");
        }

        function removeRow(btn) {
            $(btn).closest('tr').remove();
            reIndexRows();
            updateGrandTotal();
        }

        function reIndexRows() {
            $('#itemsBody tr').each(function (index, row) {
                $(row).find('input').each(function () {
                    var name = $(this).attr('name');
                    if (name) {
                        var newName = name.replace(/\[\d+\]/, '[' + index + ']');
                        $(this).attr('name', newName);
                    }
                });
            });
        }

        function updateGrandTotal() {
            var total = 0;

            $('#itemsBody tr').each(function () {
                var qty = parseFloat($(this).find('input[name*="Quantity"]').val()) || 0;
                var price = parseFloat($(this).find('input[name*="UnitPrice"]').val()) || 0;
                total += (qty * price);
            });

            var applyVat = $('#vatCheckbox').is(':checked');
            var vat = applyVat ? (total * 0.05) : 0;
            var grandTotal = total + vat;

            $('#grandTotalDisplay').val(grandTotal.toLocaleString(undefined, {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            }));
        }
    </script>
}
