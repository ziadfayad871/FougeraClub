@model IEnumerable<FougeraClub.Application.DTOs.PurchaseOrderDto>
@using FougeraClub.Application.DTOs

@{
    ViewData["Title"] = "إدارة أوامر الشراء";
    var suppliers = ViewBag.Suppliers as IEnumerable<SupplierLookupDto> ?? Enumerable.Empty<SupplierLookupDto>();
}

<div class="container-fluid rtl-container mt-2" id="purchaseOrdersPage">
    <div class="row">
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0 print-hide">
                        <li class="breadcrumb-item"><a href="/Admin/Home/Index">نادي الفجيرة العلمي</a></li>
                        <li class="breadcrumb-item active">إدارة أوامر الشراء</li>
                    </ol>
                </div>
                <div class="d-flex justify-content-end gap-2 mb-1 print-hide report-toolbar">
                    <button type="button" class="btn btn-success btn-report-action" id="printAllBtn">
                        <i class="ri-printer-line me-1"></i> طباعة
                    </button>
                    <button type="button" class="btn btn-success btn-report-action" id="exportReportBtn">
                        <i class="ri-file-excel-2-line me-1"></i> عرض تقرير
                    </button>
                </div>
                <h4 class="page-title">إدارة أوامر الشراء</h4>
            </div>
        </div>
    </div>

    <div class="row mt-1 print-hide">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body purchase-filter-card-body">
                    <div class="d-flex justify-content-end mb-2">
                        <a href="/Admin/PurchaseOrder/AddEdit" class="btn btn-success btn-sm btn-rounded mb-0 purchase-add-btn">
                            <i class="ri-add-circle-fill me-1"></i> إضافة أمر شراء
                        </a>
                    </div>

                    <form id="purchaseOrderFiltersForm" class="row g-2 align-items-end filter-form" novalidate>
                        <div class="col-xl-4 col-lg-4 col-md-6 filter-col filter-col-supplier">
                            <label class="form-label fw-bold">اسم المورد</label>
                            <select name="supplierName" id="supplierNameFilter" class="form-select">
                                <option value="">اسم المورد</option>
                                @foreach (var supplier in suppliers)
                                {
                                    <option value="@supplier.Name">@supplier.Name</option>
                                }
                            </select>
                        </div>

                        <div class="col-xl-2 col-lg-3 col-md-6 filter-col filter-col-date">
                            <label class="form-label fw-bold">من</label>
                            <input type="date" name="fromDate" id="fromDateFilter" class="form-control">
                        </div>

                        <div class="col-xl-2 col-lg-3 col-md-6 filter-col filter-col-date">
                            <label class="form-label fw-bold">إلى</label>
                            <input type="date" name="toDate" id="toDateFilter" class="form-control">
                        </div>

                        <div class="col-xl-2 col-lg-1 col-md-6 col-6 filter-col filter-col-action">
                            <button type="submit" class="btn btn-success w-100 btn-filter-action">
                                <i class="ri-filter-3-line"></i> بحث
                            </button>
                        </div>

                        <div class="col-xl-2 col-lg-1 col-md-6 col-6 filter-col filter-col-action">
                            <button type="button" class="btn btn-filter-clear w-100 btn-filter-action" id="clearFiltersBtn">
                                <i class="ri-close-line"></i> مسح
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                    <div class="purchase-table-topbar print-hide">
                        <div class="purchase-table-page-size">
                            <label for="ordersPageSize" class="purchase-table-page-size-label">عدد السجلات</label>
                            <select id="ordersPageSize" class="form-select form-select-sm purchase-table-page-size-select">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-centered table-hover mb-0 po-table-rtl" id="ordersTable">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center po-col-number">رقم أمر الشراء</th>
                                    <th class="text-center po-col-supplier">اسم المورد</th>
                                    <th class="text-center po-col-date">التاريخ</th>
                                    <th class="text-center po-col-actions print-hide">أدوات التحكم</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    foreach (var item in Model)
                                    {
                                        <tr class="po-row" data-row-id="@item.Id" data-supplier-name="@item.SupplierName" data-order-date="@item.OrderDate.ToString("yyyy-MM-dd")">
                                            <td class="text-center fw-bold text-primary">@item.OrderNumber</td>
                                            <td class="text-center">@item.SupplierName</td>
                                            <td class="text-center">@item.OrderDate.ToString("dd-MM-yyyy")</td>
                                            <td class="print-hide">
                                                <div class="d-flex justify-content-center gap-1 action-controls">
                                                    <a href="/Admin/PurchaseOrder/AddEdit?copyFromId=@item.Id" class="btn-control btn-icon btn-sm rounded-circle purchase-action-btn purchase-action-add" data-bs-toggle="tooltip" data-bs-placement="top" title="إنشاء أمر جديد">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </a>
                                                    <a
                                                        href="/Admin/PurchaseOrder/AddEdit/@item.Id"
                                                        class="btn-control btn-icon btn-sm rounded-circle purchase-action-btn purchase-action-edit js-open-edit"
                                                        data-bs-toggle="tooltip"
                                                        data-bs-placement="top"
                                                        title="تعديل">
                                                        <i class="fa-solid fa-pen-to-square"></i>
                                                    </a>
                                                    <button
                                                        type="button"
                                                        class="btn-control btn-icon btn-sm rounded-circle purchase-action-btn purchase-action-delete js-open-delete"
                                                        data-bs-toggle="tooltip"
                                                        data-bs-placement="top"
                                                        title="حذف"
                                                        data-id="@item.Id"
                                                        data-order-number="@item.OrderNumber">
                                                        <i class="fa-solid fa-trash"></i>
                                                    </button>
                                                    <a
                                                        href="/Admin/PurchaseOrder/Print/@item.Id"
                                                        class="btn-control btn-icon btn-sm rounded-circle purchase-action-btn purchase-action-print js-open-print"
                                                        data-bs-toggle="tooltip"
                                                        data-bs-placement="top"
                                                        title="طباعة">
                                                        <i class="fa-solid fa-print"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                <tr id="ordersEmptyState" style="display:@(Model.Any() ? "none" : "table-row")">
                                    <td colspan="4" class="text-center py-4 text-muted">لا توجد سجلات حالياً</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="purchase-pagination-wrap print-hide">
                        <nav aria-label="Table pagination">
                            <ul class="pagination justify-content-center mb-0" id="ordersPagination"></ul>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">حذف أمر شراء</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="deleteOrderModalText"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">إلغاء</button>
                <form method="post" asp-action="Delete" id="deleteOrderForm" class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteOrderId" />
                    <button type="submit" class="btn btn-danger">تأكيد الحذف</button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .rtl-container {
        direction: rtl;
        text-align: right;
        max-width: calc(100% - 24px);
        margin-inline: auto;
        padding-inline: 0;
    }

    .page-title-box {
        min-height: auto;
        padding: 8px 0 10px;
    }

    #purchaseOrdersPage .card {
        border-radius: 10px;
    }

    #purchaseOrdersPage .card-body.p-0 {
        padding: 0 !important;
    }

    .page-title-box .page-title {
        margin-bottom: 0;
    }

    .page-title-box .breadcrumb {
        margin-bottom: 4px !important;
    }

    .report-toolbar {
        flex-wrap: wrap;
        gap: 10px !important;
    }

    .purchase-filter-card-body {
        padding: 14px 16px 12px;
    }

    .btn-rounded {
        border-radius: 30px;
    }

    .report-toolbar .btn-report-action {
        min-width: 132px;
        height: 34px;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        gap: 6px;
        font-size: 13px;
        border: 0;
        background-color: #3fa847;
        padding-inline: 12px;
    }

    .report-toolbar .btn-report-action:hover {
        background-color: #35953d;
    }

    .btn-filter-action {
        height: 34px;
        border-radius: 4px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        font-weight: 700;
        font-size: 13px;
        border: 0;
    }

    .purchase-add-btn {
        min-width: 146px;
        height: 34px;
        padding-inline: 12px;
        font-size: 13px;
    }

    .btn-filter-clear {
        background-color: #8fd16a;
        color: #fff;
    }

    .btn-filter-clear:hover {
        background-color: #7ac058;
        color: #fff;
    }

    .filter-form .filter-col label {
        display: block;
        margin-bottom: 4px;
    }

    .filter-form .filter-col .form-control,
    .filter-form .filter-col .form-select,
    .filter-form .filter-col .btn-filter-action {
        width: 100%;
    }

    .filter-form .filter-col .form-control,
    .filter-form .filter-col .form-select {
        height: 34px;
        font-size: 13px;
    }

    @@media (min-width: 1200px) {
        .filter-form {
            display: flex;
            flex-wrap: nowrap;
            gap: 10px;
        }

        .filter-form .filter-col {
            float: none;
            padding-inline: 0;
        }

        .filter-form .filter-col-supplier {
            flex: 2.3 1 0;
            min-width: 320px;
        }

        .filter-form .filter-col-date {
            flex: 1.45 1 0;
            min-width: 230px;
        }

        .filter-form .filter-col-action {
            flex: 0 0 140px;
            min-width: 140px;
        }
    }

    .po-table-rtl {
        direction: rtl;
    }

    .po-table-rtl th,
    .po-table-rtl td {
        vertical-align: middle;
        padding-top: 0.7rem;
        padding-bottom: 0.7rem;
        white-space: nowrap;
        font-size: 13px;
    }

    @@media (max-width: 992px) {
        .report-toolbar .btn-report-action {
            min-width: 118px;
            height: 32px;
        }
    }

    .po-col-number {
        width: 14%;
        min-width: 130px;
    }

    .po-col-supplier {
        width: 46%;
        min-width: 320px;
    }

    .po-col-date {
        width: 20%;
        min-width: 150px;
    }

    .po-col-actions {
        width: 20%;
        min-width: 210px;
    }

    .purchase-table-topbar {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
        padding: 10px 14px 8px;
        background: #fff;
        border-bottom: 1px solid #edf0f2;
    }

    .purchase-pagination-wrap {
        padding: 10px 14px 12px;
        border-top: 1px solid #edf0f2;
        background: #fff;
    }

    .purchase-table-page-size {
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .purchase-table-page-size-label {
        color: #5d6773;
        font-weight: 600;
        margin: 0;
        white-space: nowrap;
    }

    .purchase-table-page-size-select {
        min-width: 68px;
        height: 32px;
        font-size: 13px;
    }

    .purchase-action-btn {
        width: 30px;
        height: 30px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        border: 1px solid #dfe5ea;
        background-color: #fff;
        color: #5d6773;
        transition: all 0.2s ease;
    }

    .purchase-action-btn:hover {
        transform: translateY(-1px);
    }

    .purchase-action-add,
    .purchase-action-print {
        color: #198754;
    }

    .purchase-action-edit {
        color: #0d6efd;
    }

    .purchase-action-delete {
        color: #dc3545;
    }

    .purchase-action-add:hover,
    .purchase-action-print:hover {
        background-color: #198754;
        border-color: #198754;
        color: #fff;
    }

    .purchase-action-edit:hover {
        background-color: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
    }

    .purchase-action-delete:hover {
        background-color: #dc3545;
        border-color: #dc3545;
        color: #fff;
    }

    .action-controls .btn,
    .action-controls .purchase-action-btn {
        width: 30px;
        height: 30px;
        min-width: 30px;
    }

    #ordersPagination .page-link {
        color: #4c5560;
        border-color: #dfe5ea;
        min-width: 32px;
        height: 32px;
        padding-inline: 9px;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
    }

    #ordersPagination .page-item.active .page-link {
        background-color: #3fa847;
        border-color: #3fa847;
        color: #fff;
    }

    #ordersPagination .page-item.disabled .page-link {
        color: #a8b0b8;
    }

    @@media (max-width: 768px) {
        .purchase-table-topbar {
            flex-direction: column;
            align-items: stretch;
        }

        .purchase-table-page-size {
            justify-content: center;
        }
    }

    @@media print {
        .print-hide,
        .action-controls,
        .modal,
        .side-nav,
        .custom-navbar,
        .breadcrumb,
        .btn,
        form {
            display: none !important;
        }

        .po-print-hidden {
            display: none !important;
        }

        .card {
            border: none;
            box-shadow: none;
        }

        .table {
            width: 100% !important;
            border: 1px solid #ddd;
        }
    }
</style>

<script src="~/js/purchase-order-index.js" asp-append-version="true"></script>
